{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": false,
    "noEmit": false
  },
  "include": ["src-ts/**/*"],
  "exclude": ["node_modules", "builds"]
}